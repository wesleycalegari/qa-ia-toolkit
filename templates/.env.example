# Azure DevOps
AZDO_PAT=seu_personal_access_token_aqui
AZDO_ORG=SuaOrganizacao
AZDO_PROJECT=SeuProjeto

# GitHub Pages
GIT_PAT=seu_github_token_aqui
GIT_USER=seu-usuario-github
GIT_REPO=planos-de-teste

# Sistema em teste (HML)
SISTEMA_URL=https://hml.seu-sistema.com
SISTEMA_USUARIO=usuario_hml
SISTEMA_SENHA=senha_hml

# Banco HML (opcional — para consulta de massa)
DB_SERVER=servidor-hml
DB_BANCO=banco-hml
DB_USER=usuario_db
DB_PASS=senha_db

# Teams webhook (opcional — para notificação ao fechar card)
TEAMS_WEBHOOK_URL=https://...powerautomate.com/...
